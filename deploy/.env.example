# Deploy-time settings (copy to deploy/.env). Backend secrets live in ../ecx-backend/.env.

# Public domain pointed at this server — Caddy auto-provisions a TLS cert for it.
# Leave as ":80" for HTTP-only / IP testing (no cert). For a real deploy set your domain.
SITE_ADDRESS=steward.example.com

# Baked into the frontend bundle at build time — MUST match INTERNAL_API_KEY in ../ecx-backend/.env.
VITE_API_KEY=dev-steward-key

# Local-test overrides for Caddy's host ports (defaults 80/443). e.g. HTTP_PORT=8080
# HTTP_PORT=80
# HTTPS_PORT=443

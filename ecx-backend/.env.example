DATABASE_URL="postgresql://steward:steward@localhost:5544/steward?schema=public"
PORT=3000

# Auth (gap #6): shared secret for the global ApiKeyGuard. Send as `x-api-key` header (web) or
# `?k=` query (Africa's Talking voice webhooks). Defaults to an insecure "dev-steward-key" if unset.
INTERNAL_API_KEY=

# Agent brain (D8): OpenRouter (OpenAI-compatible). AGENT_MODEL defaults to qwen/qwen3-235b-a22b.
OPENROUTER_API_KEY=
AGENT_MODEL=

# Voice: public, AT-reachable base URL for webhook callbacks (e.g. an ngrok URL).
PUBLIC_BASE_URL=

# Token encryption: 32-byte base64 for AES-GCM electricity-token encryption.
TOKEN_ENC_KEY=

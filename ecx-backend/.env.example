# ── Steward backend environment ─────────────────────────────────────────────
# Copy this to `.env` and fill the blanks. `docker compose up` reads `.env`.
# Blank REQUIRED values below must be filled for the corresponding feature to work.

# ── Database ────────────────────────────────────────────────────────────────
# For `docker compose up`, the app overrides this to the `postgres` service automatically.
# This value is for running the backend on your HOST against the dockerized DB (host port 5544).
DATABASE_URL="postgresql://steward:steward@localhost:5544/steward?schema=public"
PORT=3000

# ── Auth ────────────────────────────────────────────────────────────────────
# Shared API key (interim guard). Sent as `x-api-key` (web) or `?k=` (voice webhooks).
# Must match the frontend's VITE_API_KEY. Defaults to an insecure dev value if blank.
INTERNAL_API_KEY=dev-steward-key
# JWT signing secret for OTP login sessions.  REQUIRED (any long random string).
JWT_SECRET=
# Demo DTMF PIN fallback (used when a user has no argon2 PIN hash).
VOICE_DEMO_PIN=0000

# ── Agent brain (OpenRouter, OpenAI-compatible) ─────────────────────────────
# REQUIRED for the live agent. Get a key at openrouter.ai.
OPENROUTER_API_KEY=
# Smaller model = much cheaper; the policy engine is the safety net. Try qwen/qwen3-14b to save more.
AGENT_MODEL=qwen/qwen3-32b
# Cap on the agent's reply length (output tokens). Replies are short/spoken.
AGENT_MAX_TOKENS=400

# ── Speech-to-text (Whisper-compatible) ─────────────────────────────────────
# Leave STT_API_KEY blank to use the fake transcriber (canned transcripts).
# For live voice: an OpenAI or Groq key. STT_BASE_URL e.g. https://api.groq.com/openai/v1
STT_API_KEY=
STT_BASE_URL=
STT_MODEL=whisper-1

# ── Voice (Africa's Talking) ────────────────────────────────────────────────
# Public, AT-reachable base URL for webhook callbacks (e.g. an ngrok URL). REQUIRED for live calls.
PUBLIC_BASE_URL=

# ── Encryption ──────────────────────────────────────────────────────────────
# AES-GCM key for electricity-token encryption at rest (any 32+ char secret).
TOKEN_ENC_KEY=

# ── Optional ────────────────────────────────────────────────────────────────
# Absolute path to a built frontend (frontend/dist) to serve from Nest on one origin.
# FRONTEND_DIST=
